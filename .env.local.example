# =============================================================================
# SolarInvest – local development environment template
# Copy this file to .env.local and fill in the values marked <REPLACE>
# NEVER commit .env.local to version control
# =============================================================================

# -----------------------------------------------------------------------------
# Stack Auth (frontend – Vite reads VITE_* vars; NEXT_PUBLIC_* are fallbacks)
# Project: https://app.stack-auth.com/
# -----------------------------------------------------------------------------
VITE_STACK_PROJECT_ID=64612256-cc00-4e29-b694-d3944808e1a1
VITE_STACK_PUBLISHABLE_CLIENT_KEY=pck_erncv71vsryv1w4t1rfer7y15kq5we0t39vyrz2f6cek8

# Vercel / Next-style aliases (fallback read by server-side code)
NEXT_PUBLIC_STACK_PROJECT_ID=64612256-cc00-4e29-b694-d3944808e1a1
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=pck_erncv71vsryv1w4t1rfer7y15kq5we0t39vyrz2f6cek8

# -----------------------------------------------------------------------------
# Stack Auth (backend – NEVER expose to the browser)
# -----------------------------------------------------------------------------
STACK_PROJECT_ID=64612256-cc00-4e29-b694-d3944808e1a1
STACK_SECRET_SERVER_KEY=<REPLACE_WITH_YOUR_STACK_SECRET_SERVER_KEY>

# JWKS URL is auto-derived from STACK_PROJECT_ID; only override if needed
# STACK_JWKS_URL=https://api.stack-auth.com/api/v1/projects/64612256-cc00-4e29-b694-d3944808e1a1/.well-known/jwks.json

# -----------------------------------------------------------------------------
# Neon PostgreSQL – sa-east-1 (Brazil) – ep-lively-voice-aczbitc0 (project: odd-water-51591686)
# Connection strings include channel_binding=require for improved security
# REST API: https://ep-lively-voice-aczbitc0.apirest.sa-east-1.aws.neon.tech/neondb/rest/v1
# -----------------------------------------------------------------------------

# Pooled connection (PgBouncer) – recommended for serverless/edge functions
DATABASE_URL=postgresql://neondb_owner:<REPLACE_WITH_PGPASSWORD>@ep-lively-voice-aczbitc0-pooler.sa-east-1.aws.neon.tech/neondb?channel_binding=require&sslmode=require

# Direct (unpooled) connection – use for migrations and long-running queries
DATABASE_URL_UNPOOLED=postgresql://neondb_owner:<REPLACE_WITH_PGPASSWORD>@ep-lively-voice-aczbitc0.sa-east-1.aws.neon.tech/neondb?sslmode=require

# Individual PG* parameters (useful for ORMs / raw pg client)
PGHOST=ep-lively-voice-aczbitc0-pooler.sa-east-1.aws.neon.tech
PGHOST_UNPOOLED=ep-lively-voice-aczbitc0.sa-east-1.aws.neon.tech
PGUSER=neondb_owner
PGDATABASE=neondb
PGPASSWORD=<REPLACE_WITH_PGPASSWORD>

# -----------------------------------------------------------------------------
# Optional / Vercel Postgres template aliases
# -----------------------------------------------------------------------------
POSTGRES_URL=postgresql://neondb_owner:<REPLACE_WITH_PGPASSWORD>@ep-lively-voice-aczbitc0-pooler.sa-east-1.aws.neon.tech/neondb?channel_binding=require&sslmode=require
POSTGRES_URL_NON_POOLING=postgresql://neondb_owner:<REPLACE_WITH_PGPASSWORD>@ep-lively-voice-aczbitc0.sa-east-1.aws.neon.tech/neondb?channel_binding=require&sslmode=require
POSTGRES_URL_NO_SSL=postgresql://neondb_owner:<REPLACE_WITH_PGPASSWORD>@ep-lively-voice-aczbitc0-pooler.sa-east-1.aws.neon.tech/neondb
POSTGRES_PRISMA_URL=postgresql://neondb_owner:<REPLACE_WITH_PGPASSWORD>@ep-lively-voice-aczbitc0-pooler.sa-east-1.aws.neon.tech/neondb?channel_binding=require&connect_timeout=15&sslmode=require
POSTGRES_USER=neondb_owner
POSTGRES_HOST=ep-lively-voice-aczbitc0-pooler.sa-east-1.aws.neon.tech
POSTGRES_PASSWORD=<REPLACE_WITH_PGPASSWORD>
POSTGRES_DATABASE=neondb

