{
  "name": "solarinvest-app",
  "private": true,
  "version": "2.4.4",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "audit:site": "node tools/audit/site-audit.mjs",
    "audit:all": "node tools/audit/run-audit.mjs",
    "prebuild": "rm -rf node_modules/.vite && node scripts/force-rollup-wasm.js",
    "build": "node scripts/build.mjs",
    "preview": "vite preview --strictPort --port 4173",
    "pdf:serve": "npm run preview",
    "pdf:open": "xdg-open http://localhost:4173 || open http://localhost:4173 || echo 'Open http://localhost:4173 in your browser'",
    "start": "node server/index.js",
    "db:migrate": "node scripts/run-migrations.js",
    "deploy:safety-check": "node scripts/deploy/migration-safety-check.mjs",
    "deploy:snapshot": "node scripts/deploy/pre-deploy-snapshot.mjs",
    "deploy:verify": "node scripts/deploy/post-deploy-verify.mjs",
    "test": "vitest run",
    "test:server": "vitest run --config vitest.server.config.ts",
    "lint": "eslint --max-warnings=0 .",
    "lint:cycles": "madge --circular src --extensions ts,tsx",
    "check:prod": "npm run lint:cycles && vite build",
    "typecheck": "tsc --noEmit",
    "e2e:headless": "node scripts/run-e2e-placeholder.mjs",
    "test:neon": "node test-neon-connection.mjs",
    "qa:full": "npm run typecheck && npm run lint && npm run test && npm run e2e:headless",
    "check:cycles": "node scripts/find-circular-deps.mjs",
    "check:locale": "bash -lc 'if grep -R \"toLocaleString(\" src | grep -v \"pt-BR\"; then echo \"toLocaleString sem locale pt-BR encontrado\" >&2; exit 1; fi'",
    "check:printables": "vitest run --reporter=basic -t \"printable\"",
    "vercel-build-clean": "rm -rf node_modules/.vite",
    "vercel-prebuild": "rm -rf node_modules package-lock.json && npm install",
    "vercel-clean": "rm -rf node_modules .next dist .turbo",
    "prepush": "npm run lint && npm run typecheck && npm run check:cycles && npm run test",
    "postinstall": "node scripts/clean-esbuild.mjs && node scripts/copy-pagedjs-polyfill.mjs"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "@stackframe/react": "2.8.58",
    "@stackframe/stack-shared": "2.8.58",
    "@stackframe/stack-ui": "2.8.58",
    "@vercel/analytics": "^1.6.1",
    "date-fns": "^3.3.1",
    "fast-xml-parser": "^4.4.0",
    "jszip": "^3.10.1",
    "localforage": "^1.10.0",
    "lucide-react": "^0.515.0",
    "mustache": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/localforage": "^0.0.33",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.11.0",
    "@typescript-eslint/parser": "^8.11.0",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.23",
    "esbuild": "^0.27.1",
    "eslint": "^9.14.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.6",
    "jsdom": "^27.4.0",
    "madge": "^8.0.0",
    "pagedjs": "^0.4.3",
    "postcss": "^8.5.6",
    "process": "^0.11.10",
    "rollup": "4.52.4",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^3.4.19",
    "terser": "^5.33.0",
    "typescript": "^5.6.3",
    "vite": "^7.2.7",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": "24.x",
    "npm": ">=9.0.0"
  }
}
